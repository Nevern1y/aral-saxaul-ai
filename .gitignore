# Streamlit Cloud uses requirements.txt — ignore conda env
environment.yml

# Python
__pycache__/
*.py[cod]
*.egg-info/
dist/
build/
.pytest_cache/
.mypy_cache/

# Logs
*.log
*.out
*.err

# Environment
.env
.venv/
env/

# GeoTIFF rasters (too large for git)
*.tif
*.tiff
*.vrt

# Generated outputs — ignore large data, track what dashboard needs
outputs/data/*.tif
outputs/data/*.tiff
outputs/data/*.vrt
outputs/tiles/
outputs/phase1_checkpoint.json

# Generated large GeoJSON (can be regenerated from scripts)
outputs/data/optimal_zones_v*.geojson
outputs/data/operational_zones_v*.geojson

# Generated temp & bulk logistics
outputs/logistics/temp/
outputs/logistics/tractor_tasks/
outputs/logistics/tractor_tasks_v5/

# AOI boundary (optional, not needed for dashboard)
outputs/aoi/*.geojson

# IDE
.idea/
.vscode/
*.swp
*.swo

# OS
Thumbs.db
.DS_Store
